CREATE DATABASE IF NOT EXISTS database_users;

-- Create App User and Grant Permissions
CREATE USER IF NOT EXISTS 'app_user'@'localhost' IDENTIFIED BY 'admin123';
GRANT ALL PRIVILEGES ON database_users.* TO 'app_user'@'localhost';
FLUSH PRIVILEGES;

USE database_users;

CREATE TABLE users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(50) NOT NULL UNIQUE,
    password VARCHAR(255) NOT NULL
);

-- The default admin account
INSERT INTO users (username, password) VALUES ('admin', 'admin123');
